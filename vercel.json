{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.demo.html" },
    { "source": "/index.html", "destination": "/index.demo.html" },
    { "source": "/demo", "destination": "/index.demo.html" },
    { "source": "/demo/", "destination": "/index.demo.html" }
  ]
}
